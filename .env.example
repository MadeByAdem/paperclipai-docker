# =============================================================================
# Paperclip Docker — Environment Variables
# Copy to .env and fill in: cp .env.example .env
# =============================================================================

# ── Required ─────────────────────────────────────────────────────
# Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL where Paperclip will be accessible (your domain)
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# ── Database ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=paperclip

# ── AI Agent API Keys (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
